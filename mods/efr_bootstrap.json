{
  "version": 1,
  "description": "Extra Ferry Routes Proxima authoring bootstrap. Builds a blank-water island and one starting exterior scene.",
  "operations": [
    {
      "type": "create_blank_island",
      "from": "CITADEL.ILE",
      "to": "PROXIMA.ILE",
      "layout": "proxima/island_layout.json",
      "template_cube": [8, 8]
    },
    {
      "type": "copy_file",
      "from": "CITADEL.OBL",
      "to": "PROXIMA.OBL"
    },
    {
      "type": "clone_scene",
      "file": "SCENE.HQR",
      "from": 94,
      "to": 223,
      "patch": { "island": 12, "cube_x": 8, "cube_y": 8 }
    },
    {
      "type": "clone_scene",
      "file": "SCENE.HQR",
      "from": 94,
      "to": 224,
      "patch": { "island": 12, "cube_x": 8, "cube_y": 7 }
    },
    {
      "type": "include_manifest",
      "source": "proxima_island.json"
    }
  ]
}
